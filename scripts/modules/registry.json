    "classify.pass_a_faces": {
      "id": "classify.pass_a_faces",
      "version": "1.0.0",
      "type": "classify",
      "title": "MediaPipe faces / eyes / lips (Pass A base)",
      "status": "stable",
      "inputs": [
        "assets/film-grab"
      ],
      "outputs": [
        "assets/film-grab/classifications.jsonl"
      ],
      "params": {
        "skip_hands": true,
        "regeo": false,
        "force": false
      },
      "runner": {
        "kind": "python",
        "script": "scripts/fetch-film-grab/classify_pass_a.py",
        "args_from_params": {
          "skip_hands": "--skip-hands",
          "regeo": "--regeo",
          "force": "--force"
        }
      }
    },
    "classify.kiss_mouth_geo": {
      "id": "classify.kiss_mouth_geo",
      "version": "1.0.0",
      "type": "classify",
      "title": "Mouth-to-mouth Hall bands → kiss_geo",
      "status": "stable",
      "inputs": [
        "assets/film-grab"
      ],
      "outputs": [
        "assets/film-grab/classifications.jsonl"
      ],
      "params": {
        "tau_contact": 0.5,
        "tau_imminent": 1.2,
        "tau_intimate_far": 2.4,
        "regeo": true
      },
      "runner": {
        "kind": "python",
        "script": "scripts/fetch-film-grab/classify_pass_a.py",
        "fixed_args": [
          "--regeo",
          "--skip-hands"
        ],
        "note": "Geometry computed inside Pass A; --regeo upgrades multi-face rows"
      }
    },
