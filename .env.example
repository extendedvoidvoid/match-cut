# LM Studio — Qwen2.5-VL poster QC (port from poster-to-scene LOCAL_BASE_URL)
# LM_STUDIO_PORT=32768
# LM_STUDIO_BASE_URL=http://127.0.0.1:32768/v1
# LM_STUDIO_MODEL_ID=qwen_qwen2.5-vl-7b-instruct
# LM_STUDIO_CONTEXT=4096
# LM_STUDIO_PARALLEL=1
# LM_STUDIO_GPU=max
# LM_STUDIO_TEMPERATURE=0.1

# TMDB — textless movie posters (copy from projects/poster-to-scene/.env)
# TMDB_API_KEY=your_tmdb_v4_read_token

# Optional — Context7 API key for scheduled QC (see docs/CONTEXT7.md)
# Get key: https://context7.com/dashboard → Create API Key (ctx7sk-...)
# CONTEXT7_API_KEY=ctx7sk-your-key-here

# M3 Max profile overrides (defaults in docs/HARDWARE.md)
# MATCHCUT_HARDWARE_PROFILE=m3-max-48gb
# MATCHCUT_PARALLEL_JOBS=8
# MATCHCUT_CTX7_PARALLEL=4