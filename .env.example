# Optional — Context7 API key for scheduled QC (see docs/CONTEXT7.md)
# Get key: https://context7.com/dashboard → Create API Key (ctx7sk-...)
# CONTEXT7_API_KEY=ctx7sk-your-key-here

# M3 Max profile overrides (defaults in docs/HARDWARE.md)
# MATCHCUT_HARDWARE_PROFILE=m3-max-48gb
# MATCHCUT_PARALLEL_JOBS=8
# MATCHCUT_CTX7_PARALLEL=4